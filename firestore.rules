rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidConfig(data) {
      return data.keys().hasAll(['homeHeading', 'unlockedHeading', 'recipientName']) &&
             data.recipientName is string && data.recipientName.size() <= 100 &&
             data.homeHeading is string && data.homeHeading.size() <= 500 &&
             data.unlockedHeading is string && data.unlockedHeading.size() <= 500 &&
             (!('unlockedMessage' in data) || (data.unlockedMessage is string && data.unlockedMessage.size() <= 5000));
    }

    // App Configuration
    match /configs/main {
      allow read: if true; // Publicly readable for the app to function
      allow write: if isAdmin() && isValidConfig(request.resource.data);
    }

    // Admin Users
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Allow bootstrapping for the primary admin email
      allow write: if isSignedIn() && 
                    request.auth.token.email == 'deeagrawal078@gmail.com' && 
                    request.auth.token.email_verified == true &&
                    request.auth.uid == userId;
    }
  }
}
