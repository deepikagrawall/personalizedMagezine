rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'deeagrawal078@gmail.com' && 
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidProduct(data) {
      return data.keys().hasAll(['type', 'category', 'title', 'desc', 'price', 'seed']) &&
             data.type in ['pdf', 'site'] &&
             data.category is string && data.category.size() <= 100 &&
             data.title is string && data.title.size() <= 200 &&
             data.desc is string && data.desc.size() <= 2000 &&
             data.price is string && data.price.size() <= 20 &&
             data.seed is number &&
             data.keys().size() <= 15;
    }

    function isValidRequest(data) {
      return data.keys().hasAll(['productId', 'productTitle', 'name', 'email', 'phone', 'occasion']) &&
             data.productId is string && data.productTitle is string &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.occasion is string && data.occasion.size() <= 200;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() <= 50 &&
             data.keys().size() == 1;
    }

    function isValidSiteSettings(data) {
      return (data.siteName is string || !data.keys().hasAny(['siteName'])) &&
             (data.accentColor is string || !data.keys().hasAny(['accentColor'])) &&
             (data.heroTagline is string || !data.keys().hasAny(['heroTagline'])) &&
             (data.heroTitlePart1 is string || !data.keys().hasAny(['heroTitlePart1'])) &&
             (data.netflixTitle is string || !data.keys().hasAny(['netflixTitle']));
    }

    // Collection Rules
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidProduct(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['type', 'category', 'title', 'desc', 'price', 'original', 'seed', 'isNew', 'isBest', 'pdfUrl', 'videoUrl', 'imageUrl', 'updatedAt', 'whatsInside']);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isAdmin();
      allow create: if isValidRequest(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        // Non-admins can only increment views, likes, fires, claps, commentCount
        incoming().diff(existing()).affectedKeys().hasOnly(['views', 'likes', 'fires', 'claps', 'commentCount']) &&
        (!incoming().keys().hasAny(['views']) || incoming().views is number) &&
        (!incoming().keys().hasAny(['likes']) || incoming().likes is number) &&
        (!incoming().keys().hasAny(['fires']) || incoming().fires is number) &&
        (!incoming().keys().hasAny(['claps']) || incoming().claps is number) &&
        (!incoming().keys().hasAny(['commentCount']) || incoming().commentCount is number)
      );
    }

    match /blogs/{blogId}/comments/{commentId} {
      allow read: if true;
      allow create: if incoming().keys().hasAll(['name', 'text', 'createdAt']) &&
                    incoming().name is string && incoming().name.size() <= 100 &&
                    incoming().text is string && incoming().text.size() <= 1000 &&
                    incoming().createdAt == request.time &&
                    incoming().keys().size() == 3;
      allow update, delete: if isAdmin();
    }

    match /newsletter/{newsletterId} {
      allow create: if incoming().keys().hasAll(['email', 'subscribedAt', 'source']) &&
                    incoming().email is string && incoming().email.size() <= 150 &&
                    incoming().subscribedAt == request.time &&
                    incoming().source is string && incoming().source.size() <= 50 &&
                    incoming().keys().size() == 3;
      allow read, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSiteSettings(incoming());
    }
  }
}
