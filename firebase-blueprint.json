{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A template product (PDF or Website)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "site"] },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "price": { "type": "string" },
        "original": { "type": "string" },
        "seed": { "type": "number" },
        "isNew": { "type": "boolean" },
        "isBest": { "type": "boolean" },
        "whatsInside": { "type": "array", "items": { "type": "string" } },
        "pdfUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "category", "title", "seed"]
    },
    "Request": {
      "title": "Request",
      "description": "User lead request for a template",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productTitle": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "occasion": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "contacted", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "name", "email"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all templates"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories"
    },
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Collection of user lead requests"
    }
  }
}
