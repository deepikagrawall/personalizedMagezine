{
  "entities": {
    "appConfig": {
      "title": "App Configuration",
      "description": "Stores the dynamic content for the app.",
      "type": "object",
      "properties": {
        "recipientName": { "type": "string" },
        "homeHeading": { "type": "string" },
        "birthdaySurpriseTitle": { "type": "string" },
        "birthdaySurpriseSub": { "type": "string" },
        "unlockedHeading": { "type": "string" },
        "unlockedSubHeading": { "type": "string" },
        "unlockedMessage": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "unlockCode": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["homeHeading", "unlockedHeading"]
    },
    "admin": {
      "title": "Admin User",
      "description": "Stores admin user information.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "configs/main": {
      "schema": "appConfig",
      "description": "The main configuration document."
    },
    "admins/{userId}": {
      "schema": "admin",
      "description": "Admin users collection."
    }
  }
}
